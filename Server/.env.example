# Copy this file to `.env` and fill the values.
# Do NOT commit your real API key. Keep `.env` out of version control.

# MongoDB connection string
# Local Docker example:
# MONGODB_URL=mongodb://admin:admin123@localhost:27017/AutoShare?authSource=admin
MONGODB_URL=your_mongodb_connection_string_here
MONGODB_DB_NAME=AutoShare

# Firebase Web API Key (used for email/password sign-in via Firebase REST API)
FIREBASE_API_KEY=your_firebase_web_api_key_here

# Path to service account inside the container (docker-compose mounts ./secrets)
FIREBASE_CREDENTIAL_PATH=/secrets/firebase-service-account.json
